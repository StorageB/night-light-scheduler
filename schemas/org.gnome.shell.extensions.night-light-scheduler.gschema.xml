<?xml version="1.0" encoding="UTF-8" ?>
<schemalist>
  <schema id="org.gnome.shell.extensions.night-light-scheduler" path="/org/gnome/shell/extensions/night-light-scheduler/">

    <key name="schedule" type="a(uuu)">
        <default>
        [
            (0, 0, 2400),
            (6, 0, 3150),
            (7, 30, 3900),
            (9, 0, 4700),
            (18, 45, 3900),
            (21, 0, 3150),
            (23, 0, 2400)
        ]
        </default>
        <summary>Night Light schedule</summary>
        <description>Array of schedule entries: (hour, minute, temperature).</description>
    </key>

    <key name="transition-time" type="i">
        <default>15</default>
        <summary>Temperature transition time</summary>
        <description>Length of time to transition between the scheduled temperatures.</description>
    </key>
    
  </schema>
</schemalist>
